# Optional: enable the live Unsplash photo gallery in each country panel.
#
# 1. Create a free app at https://unsplash.com/developers
# 2. Copy the "Access Key" (the public one, NOT the Secret Key).
# 3. Create a file named ".env.local" (gitignored) and put your key there:
#
#      VITE_UNSPLASH_ACCESS_KEY=your_access_key_here
#
# Do NOT put real keys in this file (.env.example is committed to git).
VITE_UNSPLASH_ACCESS_KEY=
